          "rawSql": "SELECT CONCAT(egressNetworkPolicyNamespace, '/', egressNetworkPolicyName) as policy,\ncount() as denied_count\nFROM flows_policy_view\nWHERE $__timeFilter(flowEndSeconds)\nAND egressNetworkPolicyRuleAction IN (2,3)\nAND egressNetworkPolicyName != ''\nGROUP BY policy\nORDER BY denied_count DESC\nLIMIT ${topN}",
