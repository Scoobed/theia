      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "format": 2,
          "queryType": "sql",
          "rawSql": "SELECT $__timeInterval(flowEndSeconds) as time,\nCASE\n  WHEN egressNetworkPolicyRuleAction IN (2,3) AND egressNetworkPolicyName != ''\n    THEN CONCAT('egress:', egressNetworkPolicyNamespace, '/', egressNetworkPolicyName)\n  WHEN ingressNetworkPolicyRuleAction IN (2,3) AND ingressNetworkPolicyName != ''\n    THEN CONCAT('ingress:', ingressNetworkPolicyNamespace, '/', ingressNetworkPolicyName)\n  ELSE 'unknown'\nEND as rule,\ncount() as denied_count\nFROM flows_policy_view\nWHERE $__timeFilter(time)\nAND (\n  ('${direction}' = 'egress' AND egressNetworkPolicyRuleAction IN (2,3))\n  OR ('${direction}' = 'ingress' AND ingressNetworkPolicyRuleAction IN (2,3))\n  OR ('${direction}' = 'both' AND (egressNetworkPolicyRuleAction IN (2,3) OR ingressNetworkPolicyRuleAction IN (2,3)))\n)\nGROUP BY time, rule\nHAVING denied_count > 0\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Denied Rules Over Time",
      "type": "timeseries"
    },
