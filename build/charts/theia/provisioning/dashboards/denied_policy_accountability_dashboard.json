      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\nsourcePodNamespace,\ndestinationIP,\nCAST(destinationTransportPort AS VARCHAR) as destinationPort,\nCASE\n  WHEN egressNetworkPolicyRuleAction IN (2,3) THEN 'egress'\n  WHEN ingressNetworkPolicyRuleAction IN (2,3) THEN 'ingress'\n  ELSE 'unknown'\nEND as deny_direction,\nCASE\n  WHEN egressNetworkPolicyRuleAction IN (2,3) THEN egressNetworkPolicyRuleAction\n  ELSE ingressNetworkPolicyRuleAction\nEND as action,\nCASE\n  WHEN egressNetworkPolicyRuleAction IN (2,3) THEN CONCAT(egressNetworkPolicyNamespace, '/', egressNetworkPolicyName)\n  ELSE CONCAT(ingressNetworkPolicyNamespace, '/', ingressNetworkPolicyName)\nEND as policy,\ncount() as denied_count,\nSUM(octetDeltaCount) as denied_bytes\nFROM flows_policy_view\nWHERE $__timeFilter(flowEndSeconds)\nAND (\n  ('${direction}' = 'egress' AND egressNetworkPolicyRuleAction IN (2,3))\n  OR ('${direction}' = 'ingress' AND ingressNetworkPolicyRuleAction IN (2,3))\n  OR ('${direction}' = 'both' AND (egressNetworkPolicyRuleAction IN (2,3) OR ingressNetworkPolicyRuleAction IN (2,3)))\n)\nGROUP BY sourcePodNamespace, destinationIP, destinationPort, deny_direction, action, policy\nORDER BY denied_count DESC\nLIMIT ${topN}",
          "refId": "A"
        }
      ],
      "title": "Deny Triage Table",
      "type": "table"
    }
