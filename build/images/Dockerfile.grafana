FROM grafana/grafana:13.0.2

USER root

# Create custom plugins directory outside the PVC mount path
RUN mkdir -p /opt/grafana/plugins

# Install the ClickHouse datasource plugin to the custom path
RUN grafana cli --pluginsDir /opt/grafana/plugins plugins install grafana-clickhouse-datasource
COPY plugins/grafana-custom-plugins/grafana-sankey-plugin/dist/ /opt/grafana/plugins/theia-grafana-sankey-plugin/
COPY plugins/grafana-custom-plugins/grafana-chord-plugin/dist/ /opt/grafana/plugins/theia-grafana-chord-plugin/
COPY plugins/grafana-custom-plugins/grafana-dependency-plugin/dist/ /opt/grafana/plugins/theia-grafana-dependency-plugin/

# Fix ownership
RUN chown -R grafana:root /opt/grafana/plugins/

# Point Grafana to the custom plugins path and allow unsigned plugins
ENV GF_PATHS_PLUGINS=/opt/grafana/plugins
ENV GF_PLUGINS_ALLOW_LOADING_UNSIGNED_PLUGINS=theia-grafana-sankey-plugin,theia-grafana-chord-plugin,theia-grafana-dependency-plugin

USER grafana
